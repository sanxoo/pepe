{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "default": {
            "format" : "%(asctime)s %(levelname)-8s %(filename)s:%(lineno)3d : %(message)s"
        }
    },
    "handlers": {
        "default" : {
            "formatter": "default",
            "class": "logging.handlers.TimedRotatingFileHandler",
            "filename": "log/main.log",
            "when": "d",
            "backupCount": 7
        }
    },
    "loggers": {
        "": {
            "handlers": ["default"], "level": "DEBUG"
        }
    }
}
