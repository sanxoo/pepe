{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "default": {
            "format" : "%(asctime)s %(levelname)-8s %(filename)s:%(lineno)3d : %(message)s"
        }
    },
    "handlers": {
        "default" : {
            "formatter": "default", "class": "logging.StreamHandler", "stream": "ext://sys.stdout"
        }
    },
    "loggers": {
        "": {
            "handlers": ["default"], "level": "DEBUG"
        }
    }
}
